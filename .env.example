# PostgreSQL
DATABASE_URL=postgresql://lookout:lookout@localhost:5433/lookout

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=lookout
R2_PUBLIC_DOMAIN=your-bucket.r2.dev

# Global API key — full access, tags no program. (Formerly INTERNAL_API_KEY,
# which is still accepted as a fallback.) Issue per-program keys at /admin.
GLOBAL_API_KEY=change-me-to-a-random-secret

# Admin dashboard (HTTP basic auth at /admin). Leave unset to disable it.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Sentry
SENTRY_DSN=

# App
PORT=3000
BASE_URL=http://localhost:3000
